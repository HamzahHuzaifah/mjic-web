datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-1.1.x", "rhel-openssl-3.0.x", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

// 1. User Model (untuk login Admin)
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique @db.VarChar(191)
  password  String   @db.VarChar(255) // Hashed password
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]

  @@index([email])
}

// 2. Post Model (untuk Berita/Artikel kegiatan sekolah)
model Post {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(255)
  content     String    @db.Text // Tipe data TEXT efisien untuk konten artikel panjang
  image       String?   @db.VarChar(255) // Path / URL gambar utama
  published   Boolean   @default(false)
  publishedAt DateTime? // Tanggal publish berita
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  authorId    Int
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@index([authorId])
}

// 3. Program Model (untuk Program Pendidikan)
model Program {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(150) // e.g. Madrasah Ibtidaiyah (MI)
  slug        String   @unique @db.VarChar(150)
  description String   @db.VarChar(500) // Deskripsi singkat
  icon        String?  @db.VarChar(100) // Nama ikon (e.g. "book-open", "microscope")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

// 4. Staff Model (untuk data Guru/Karyawan)
model Staff {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(150)
  position  String   @db.VarChar(100) // Jabatan (e.g. Kepala Sekolah, Guru Matematika)
  photo     String?  @db.VarChar(255) // Path / URL foto staff
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 5. SMPB Model (Pendaftaran Peserta Didik Baru - Menjaga kompatibilitas dengan UI)
model Registration {
  id                Int                @id @default(autoincrement())
  fullName          String             @db.VarChar(150)
  email             String             @db.VarChar(191)
  phone             String             @db.VarChar(30)
  programOfInterest String             @db.VarChar(100)
  address           String             @db.Text
  status            RegistrationStatus @default(PENDING)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

// 6. Setting Model (Pengaturan Website - Menjaga kompatibilitas dengan UI)
model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique @db.VarChar(100)
  value String @db.Text
}

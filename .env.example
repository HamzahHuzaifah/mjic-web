# Database Connection (MySQL - cPanel)
# Ganti dengan kredensial database MySQL Anda di cPanel
DATABASE_URL="mysql://username:password@localhost:3306/nama_database"

# NextAuth / Auth.js Configuration (Jika digunakan untuk login admin)
# Generate secret dengan: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-auth-key-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Application URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
